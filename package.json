{
  "name": "homepage",
  "version": "1.0.0",
  "private": true,
  "description": "Lolipop's homepage and static blog system, inspired by Priority Vision theme Thesis",
  "author": "LolipopJ",
  "keywords": [
    "gatsby",
    "homepage",
    "blog"
  ],
  "engines": {
    "node": ">= 24",
    "pnpm": ">= 9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "gatsby",
      "gatsby-cli",
      "sharp"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "lint": "npm run prettier && npm run eslint",
    "eslint": "eslint --fix **/*.{js,ts,jsx,tsx,md,mdx}",
    "prettier": "prettier --write .",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{json,css}": [
      "prettier --write"
    ],
    "*.{js,ts,jsx,tsx,md,mdx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.13",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@mdx-js/react": "^3.1.1",
    "@react-spring/web": "^10.0.3",
    "@types/lodash-es": "^4.17.12",
    "algoliasearch": "^5.50.2",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "gatsby": "^5.16.1",
    "gatsby-plugin-algolia": "^1.0.3",
    "gatsby-plugin-feed": "^5.16.0",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-layout": "^4.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-mdx": "^5.16.0",
    "gatsby-plugin-postcss": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-remark-copy-linked-files": "^6.16.0",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-remark-prismjs": "^7.16.0",
    "gatsby-remark-responsive-iframe": "^6.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "gitalk-react": "^1.0.0",
    "heti": "^0.9.6",
    "lodash-es": "^4.18.1",
    "nprogress": "^0.2.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-instantsearch": "^7.29.0",
    "remark-gfm": "^3.0.1",
    "rich-presence-react": "^1.0.0-beta.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mermaid": "^11.14.0",
    "postcss": "^8.5.9",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "resolutions": {
    "eslint": "^9.39.4"
  }
}
